# LLM 运行参数（可选，作为首次启动时的默认值）
# 模型选择、API Key 请在运行后通过系统界面「服务商」标签页配置，无需在此设置
LLM__MAX_TOKENS=4096
LLM__TEMPERATURE=0.1
LLM__CONTEXT_WINDOW_TOKENS=65536
LLM__MAX_ITERATIONS=40

TOOLS__BRAVE_API_KEY=BSA-xxx
TOOLS__RESTRICT_TO_WORKSPACE=true
TOOLS__SHELL_TIMEOUT=30

WORKSPACE=./workspace
SKILLS_DIR=./skills
